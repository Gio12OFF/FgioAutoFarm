    -- Переменные
    local Farming = false
    local CurrentIndex = 1
    local CanTeleport = true
    local WaitingForRespawn = false
    local Platforms = {}
    local CooldownThread = nil
    local ToggleTween = nil

    -- Создаём anchored платформы (розовые)
    local function CreateAllPlatforms()
        for _, plat in ipairs(Platforms) do
            if plat and plat.Parent then
                plat:Destroy()
            end
        end
        Platforms = {}
        
        for i, coord in ipairs(Coordinates) do
            local plat = Instance.new("Part")
            plat.Name = "FarmPlatform_" .. i
            plat.Size = Vector3.new(10, 0.5, 10)
            plat.Anchored = true
            plat.CanCollide = true
            plat.Transparency = 0.8
            plat.Color = Color3.fromRGB(200, 80, 180)
            plat.Material = Enum.Material.SmoothPlastic
            plat.Position = Vector3.new(coord.X, coord.Y - 3.5, coord.Z)
            plat.Parent = workspace
            
            table.insert(Platforms, plat)
        end
    end

    -- ФУНКЦИЯ CLAIM RIVER RESULTS GOLD
    local function ClaimRiverGold()
        local success, result = pcall(function()
            local claimPart = workspace:WaitForChild("ClaimRiverResultsGold", 2)
            if claimPart then
                fireclickdetector(claimPart:FindFirstChild("ClickDetector") or claimPart)
                CurrentStatusLabel.Text = "● Забрано золото!"
                return true
            else
                CurrentStatusLabel.Text = "● ClaimRiverResultsGold не найден"
                return false
            end
        end)
        if not success then
            CurrentStatusLabel.Text = "● Ошибка ClaimRiverResultsGold"
        end
        return success
    end

    -- Анимация тумблера
    local function AnimateToggle(on)
        if ToggleTween then ToggleTween:Cancel() end
        
        local goal = on and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        local bgColor = on and Color3.fromRGB(255, 100, 200) or Color3.fromRGB(80, 30, 65)
        
        ToggleTween = TweenService:Create(ToggleKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = goal})
        ToggleTween:Play()
        
        TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = bgColor}):Play()
    end

    -- Обновление прогресс-бара
    local function UpdateProgress(current, total)
        local ratio = math.clamp(current / total, 0, 1)
        TweenService:Create(ProgressFill, TweenInfo.new(0.3), {Size = UDim2.new(ratio, 0, 1, 0)}):Play()
        ProgressLabel.Text = "Прогресс: " .. current .. "/" .. total .. " точек"
    end

    -- Функция телепорта
    local function TeleportToPoint(index)
        if not CanTeleport then return end
        if not Farming then return end
        if WaitingForRespawn then return end
        
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then 
            CanTeleport = true
            return 
        end
        
        CanTeleport = false
        
        local target = Coordinates[index]
        char.HumanoidRootPart.CFrame = CFrame.new(target)
        
        UpdateProgress(index, #Coordinates)
        CurrentStatusLabel.Text = "● ТП " .. index .. "/" .. #Coordinates
        
        if index >= #Coordinates then
            WaitingForRespawn = true
            CurrentStatusLabel.Text = "● Ожидание смерти..."
            StatusText.Text = "ОЖИДАНИЕ"
            StatusDot.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
            CanTeleport = true
            
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.Died:Connect(function()
                    if not Farming then return end
                    CurrentStatusLabel.Text = "● Ожидание респавна..."
                    StatusText.Text = "РЕСПАВН"
                    StatusDot.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
                end)
            end
        else
            local delayMs = tonumber(DelayTPBox.Text) or 400
            local delaySec = math.max(delayMs / 1000, 0.1)
            
            task.delay(delaySec, function()
                CanTeleport = true
                if Farming and not WaitingForRespawn then
                    CurrentIndex = CurrentIndex + 1
                    TeleportToPoint(CurrentIndex)
                end
            end)
        end
    end

    -- Запуск фарма
    local function StartFarm()
        Farming = true
        FarmStatus = true
        CanTeleport = true
        WaitingForRespawn = false
        CurrentIndex = 1
        StatusText.Text = "АКТИВЕН ✨"
        StatusDot.BackgroundColor3 = Color3.fromRGB(255, 100, 200)
        CurrentStatusLabel.Text = "● Запуск..."
        UpdateProgress(0, #Coordinates)
        
        AnimateToggle(true)
        CreateAllPlatforms()
        TeleportToPoint(CurrentIndex)
    end

    -- Остановка фарма
    local function StopFarm()
        Farming = false
        FarmStatus = false
        CanTeleport = true
        WaitingForRespawn = false
        StatusText.Text = "НЕАКТИВЕН"
        StatusDot.BackgroundColor3 = Color3.fromRGB(255, 50, 150)
        CurrentStatusLabel.Text = "● Остановлен"
        UpdateProgress(0, #Coordinates)
        
        AnimateToggle(false)
        
        if CooldownThread then
            task.cancel(CooldownThread)
            CooldownThread = nil
        end
        
        for _, plat in ipairs(Platforms) do
            if plat and plat.Parent then
                plat:Destroy()
            end
        end
        Platforms = {}
    end

    -- Клик по тумблеру
    ToggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if Farming then
                StopFarm()
            else
                StartFarm()
            end
        end
    end)

    -- Обработка респавна с кулдауном и CLAIM RIVER GOLD
    LocalPlayer.CharacterAdded:Connect(function(char)
        if not Farming then return end
        if not WaitingForRespawn then return end
        
        local cooldownSec = tonumber(CooldownBox.Text) or 4
        cooldownSec = math.max(cooldownSec, 0)
        
        StatusText.Text = "КУЛДАУН"
        StatusDot.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
        
        task.wait(0.5)
        
        local rootPart = char:WaitForChild("HumanoidRootPart", 5)
        if not rootPart then return end
        
        task.spawn(function()
            ClaimRiverGold()
        end)
        
        CooldownThread = task.spawn(function()
            for i = cooldownSec, 1, -1 do
                if not Farming then return end
                CurrentStatusLabel.Text = "● Кулдаун: " .. i .. "с"
                task.wait(1)
            end
            
            if Farming and WaitingForRespawn then
                WaitingForRespawn = false
                CurrentIndex = 1
                CanTeleport = true
                StatusText.Text = "АКТИВЕН ✨"
                StatusDot.BackgroundColor3 = Color3.fromRGB(255, 100, 200)
                CurrentStatusLabel.Text = "● Продолжаем..."
                
                CreateAllPlatforms()
                TeleportToPoint(CurrentIndex)
            end
        end)
    end)

