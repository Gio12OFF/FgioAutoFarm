    local function AnimateAntiAFKToggle(on)
        if AntiAFKToggleTween then 
            AntiAFKToggleTween:Cancel() 
            AntiAFKToggleTween = nil
        end
        
        local goal = on and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        local bgColor = on and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(80, 30, 65)
        local dotColor = on and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 50, 150)
        
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        
        AntiAFKToggleTween = TweenService:Create(AntiAFKToggleKnob, tweenInfo, {Position = goal})
        AntiAFKToggleTween:Play()
        
        TweenService:Create(AntiAFKToggleFrame, tweenInfo, {BackgroundColor3 = bgColor}):Play()
        TweenService:Create(AntiAFKStatusDot, tweenInfo, {BackgroundColor3 = dotColor}):Play()
        
        AntiAFKStatusText.Text = on and "АНТИ-АФК: ВКЛ 🛡️" or "АНТИ-АФК: ВЫКЛ"
    end

